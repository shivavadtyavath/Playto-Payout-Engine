# Leave DATABASE_URL empty to use SQLite (fine for local UI testing)
# Set to PostgreSQL URL for production / concurrency tests
DATABASE_URL=

# Leave REDIS_URL empty to run Celery tasks synchronously (no Redis needed)
# Set to Redis URL for production / background worker mode
REDIS_URL=

DJANGO_SECRET_KEY=local-dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
